# Docker 镜像地址。GitHub Actions 默认推送到 ghcr.io/<owner>/sub2-monitor:latest
APP_IMAGE=ghcr.io/YOUR_GITHUB_USER_OR_ORG/sub2-monitor:latest

# 宿主机访问端口。访问 http://服务器IP:8080
APP_PORT=8080

# Redis 默认使用 docker-compose.yml 中的 redis 服务。
# 如果要复用服务器上已有 Redis 容器，请把 REDIS_HOST 改成该容器在同一 Docker 网络内可解析的容器名。
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# MySQL 信息请按服务器实际情况手动修改。
MYSQL_MASTER_URL=jdbc:mysql://MYSQL_HOST:3306/sub2_monitor?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
MYSQL_MASTER_USERNAME=MYSQL_USER
MYSQL_MASTER_PASSWORD=MYSQL_PASSWORD

# 没有从库时保持和主库一致即可。
MYSQL_SLAVE_URL=jdbc:mysql://MYSQL_HOST:3306/sub2_monitor?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
MYSQL_SLAVE_USERNAME=MYSQL_USER
MYSQL_SLAVE_PASSWORD=MYSQL_PASSWORD
